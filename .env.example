# =============================================================================
# Calvin RAG Chatbot - 환경변수
# =============================================================================
# 이 파일을 .env로 복사한 뒤 OPENAI_API_KEY를 채우세요:
#   cp .env.example .env

# OpenAI (필수)
OPENAI_API_KEY=sk-your-key-here

# 모델
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# 공통 RAG 파라미터
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Hybrid RAG 파라미터
DENSE_WEIGHT=0.5
RRF_K=60

# Reranker (.[rerank] 설치 후에만 동작)
RERANKER_ENABLED=false
RERANKER_TOP_K=5

# Self-RAG / Groundedness check
SELF_RAG_ENABLED=false
MAX_SELF_RAG_RETRIES=2

# Agent 파라미터
AGENT_RECURSION_LIMIT=10
ENABLE_LLM_CACHE=true

# =============================================================================
# 데이터/인덱스 경로 (선택)
# =============================================================================
# 미설정 시 이 repo의 data/, indexes/ 폴더를 사용.
# 학습 repo(rag-study-tracks)와 데이터/인덱스를 공유하려면 절대경로 지정:
#
# CALVIN_PDF_PATH=/Users/<user>/project/.../rag-study-tracks/data/calvin/calvin_institutes.pdf
# INDEX_DIR=/Users/<user>/project/.../rag-study-tracks/indexes

# CALVIN_PDF_PATH=
# INDEX_DIR=

# =============================================================================
# Knowledge Graph 모드 (v2, .[kg] 옵션 그룹 설치 후 사용)
# =============================================================================
# Neo4j 백엔드 연결 정보. 어댑터(Neo4jAdapter)는 URI scheme으로 local/aura 자동 감지.
#
# (1) 로컬 Docker (개발용, 권장):
#     docker compose up -d
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
#
# (2) Neo4j Aura Free (시연/배포용):
#     https://console.neo4j.io 가입 → Free Database 생성 → 자동 생성 비번 다운로드
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=<aura에서 생성된 비번>

# KG 인덱싱 대상 단원 (page 범위 콤마 구분, 1-indexed)
# 미설정 시 rag_core/kg/extractor.py 의 DEFAULT_CALVIN_SECTIONS 사용
# KG_SECTION_PAGES=

