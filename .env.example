# =============================================================================
# Calvin RAG Chatbot - 환경변수
# =============================================================================
# 이 파일을 .env로 복사한 뒤 OPENAI_API_KEY를 채우세요:
#   cp .env.example .env

# OpenAI (필수)
OPENAI_API_KEY=sk-your-key-here

# 모델
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# 공통 RAG 파라미터
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Hybrid RAG 파라미터
DENSE_WEIGHT=0.5
RRF_K=60

# Reranker (.[rerank] 설치 후에만 동작)
RERANKER_ENABLED=false
RERANKER_TOP_K=5

# Self-RAG / Groundedness check
SELF_RAG_ENABLED=false
MAX_SELF_RAG_RETRIES=2

# Agent 파라미터
AGENT_RECURSION_LIMIT=10
ENABLE_LLM_CACHE=true

# =============================================================================
# 데이터/인덱스 경로 (선택)
# =============================================================================
# 미설정 시 이 repo의 data/, indexes/ 폴더를 사용.
# 학습 repo(rag-study-tracks)와 데이터/인덱스를 공유하려면 절대경로 지정:
#
# CALVIN_PDF_PATH=/Users/<user>/project/.../rag-study-tracks/data/calvin/calvin_institutes.pdf
# INDEX_DIR=/Users/<user>/project/.../rag-study-tracks/indexes

# CALVIN_PDF_PATH=
# INDEX_DIR=

# =============================================================================
# Knowledge Graph 모드 (v2, .[kg] 옵션 그룹 설치 후 사용)
# =============================================================================
# Neo4j 백엔드 연결 정보. 어댑터(Neo4jAdapter)는 URI scheme으로 local/aura 자동 감지.
#
# (1) 로컬 Docker (개발용, 권장):
#     docker compose up -d

#
# (2) Neo4j Aura Free (시연/배포용):
#     https://console.neo4j.io 가입 → Free Database 생성 → 자동 생성 비번 다운로드
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=<aura에서 생성된 비번>
# NEO4J_DATABASE=neo4j   # 미설정 시 'neo4j'. 일부 신규 Aura 인스턴스는 인스턴스 ID 가 db 명

# KG 인덱싱 대상 단원 (page 범위 콤마 구분, 1-indexed)
# 미설정 시 rag_core/kg/extractor.py 의 DEFAULT_CALVIN_SECTIONS 사용
# KG_SECTION_PAGES=

# =============================================================================
# 외부 노출 / 운영 (배포 시 주입)
# =============================================================================

# 서버 포트
# - 로컬: 8000 (관행)
# - HF Spaces: 7860 (강제, frontmatter app_port 와 일치)
# - Fly.io: PORT 를 동적으로 주입 — 미설정해도 Dockerfile 기본값 7860 사용
# PORT=8000

# 인덱스 디렉토리 — 미설정 시 repo 의 indexes/ 사용
# - 컨테이너 배포 시 부팅 스크립트가 HF Dataset 에서 /app/indexes 로 fetch
# - 외부 volume 마운트가 필요한 경우만 override
# INDEX_DIR=

# 인덱스 storage 분리 (저작권 보호) — 부팅 시 Private HF Dataset 에서 fetch
# - 미설정 시: image 또는 로컬 indexes/ 가 있어야 부팅 가능 (개발 모드)
# - 운영(HF Space): 두 변수 모두 설정 필요
#   1) HF_INDEX_REPO = "<HF_USER>/calvin-rag-indexes"  (Private Dataset)
#   2) HF_TOKEN      = read 권한 토큰 (Space Secret 으로 주입)
# 인덱스 push: python scripts/push_index_to_hf.py
# HF_INDEX_REPO=
# HF_TOKEN=

# CORS — 콤마 구분 origin. 미설정 시 와일드카드 (개발 모드, credentials 비활성).
# 운영: Vercel 배포 도메인만 허용
# CORS_ORIGINS=https://your-app.vercel.app,https://chat.example.com

# 초대 코드 (PRD-5) — 콤마 구분. 미설정 시 InviteGate 자동 통과 (개발 모드)
# INVITE_CODES=portfolio2026,demo-friend,interview-abc

# Vision 모드 (PRD-1, 비용 가드) — 외부 노출 단계엔 false 권장
# VISION_ENABLED=true

# 라우터 LLM 분류기 (PRD-3) — 휴리스틱 fallback 자동 보장
# ROUTER_LLM_CLASSIFIER=false

# Budget — 사용자/IP 별 일일 토큰 한도 (PRD-4)
# BUDGET_FREE_CAP=10000
# BUDGET_PAID_CAP=100000
# DAILY_TOKEN_CAP=1000000

# Rate limit (slowapi)
# RATE_LIMIT_PER_MINUTE=10
# RATE_LIMIT_PER_DAY=200

# Audit log DB (SQLite)
# AUDIT_DB_PATH=~/.calvin-rag-chatbot/audit.db

# 알림 (PRD-4, 미설정 시 noop)
# SENTRY_DSN=https://...@sentry.io/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Log sink (PRD-4)
# LOG_SINK=stdout

# Budget store backend
# BUDGET_STORE=memory  # 또는 redis (REDIS_URL 필요)
# REDIS_URL=

# =============================================================================
# Frontend (web/.env.local)
# =============================================================================
# 별도 web/.env.local 에 배치:
# NEXT_PUBLIC_API_BASE=https://<HF_USER>-calvin-rag-api.hf.space    # HF Spaces 메인
# NEXT_PUBLIC_API_BASE=https://calvin-rag-api.fly.dev               # Fly.io fallback
